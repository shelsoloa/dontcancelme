# Copy to .env.local and fill in. Values here are placeholders, not secrets.

# --- Public (sent to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY= # publishable key (sb_publishable_...)
NEXT_PUBLIC_ENABLE_DEV_LOGIN=true     # local-only email login; never set in prod

# X client credentials
X_CLIENT_ID=                          # X app (OAuth 2.0, confidential) client id
X_CLIENT_SECRET=                      # X app client secret
X_CLIENT_BEARER_TOKEN=                # X app bearer token

# --- Server-only secrets (NEVER prefix with NEXT_PUBLIC) ---
SUPABASE_SECRET_KEY=                 # secret key (sb_secret_...) — bypasses RLS
APP_ENCRYPTION_KEY=                   # base64 32 bytes: `openssl rand -base64 32`

# Stripe (test mode)
STRIPE_SECRET_KEY=                    # sk_test_… from the Stripe dashboard
STRIPE_WEBHOOK_SECRET=                # whsec_… from `stripe listen`
STRIPE_PRICE_ID=                      # price_… one-time price, unit = 1 block of 500 tweets

# OpenAI (omni-moderation-latest, free endpoint — required for Phase 2 moderation)
OPENAI_API_KEY=

# --- Supabase X provider (read by the local stack at `supabase start`) ---
# Set these in the repo-root .env (same X app credentials as above).
# SUPABASE_AUTH_EXTERNAL_X_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_X_SECRET=
